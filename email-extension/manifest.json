{
  "manifest_version": 3,
  "name": "Spam Detector",
  "version": "1.0",
  "permissions": ["activeTab"],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}